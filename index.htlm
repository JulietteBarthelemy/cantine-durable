<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Suivi des Déchets - Canti-Gâchis v2 (Grammes)</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f7faf7; color: #2d3748; margin: 0; padding: 20px; }
        .wrapper { max-width: 1000px; margin: 0 auto; }
        header { background-color: #1b4d3e; color: white; padding: 30px; text-align: center; border-radius: 12px; margin-bottom: 25px; }
        header h1 { margin: 0 0 10px 0; font-size: 24px; }
        header p { margin: 0; font-size: 16px; opacity: 0.9; }
        .zone-saisie { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); margin-bottom: 25px; border-left: 6px solid #dd6b20; }
        .zone-saisie h3 { margin-top: 0; color: #1b4d3e; }
        .form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 15px; margin-top: 15px; }
        .form-group { display: flex; flex-direction: column; }
        .form-group label { font-size: 13px; font-weight: bold; margin-bottom: 8px; color: #4a5568; }
        .form-group input { padding: 10px; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 16px; font-weight: bold; }
        .actions-btn { display: flex; gap: 10px; grid-column: 1 / -1; justify-content: flex-end; margin-top: 10px; }
        .btn { padding: 12px 20px; border-radius: 8px; cursor: pointer; font-weight: bold; border: none; font-size: 14px; }
        .btn-calculer { background-color: #1b4d3e; color: white; }
        .btn-effacer { background-color: #e53e3e; color: white; }
        .statut-sauvegarde { font-size: 13px; color: #2b6cb0; font-style: italic; margin-top: 12px; font-weight: bold; }
        .bloc-dechets { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 15px; margin-bottom: 35px; }
        .carte { background: white; padding: 15px; border-radius: 12px; text-align: center; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border-top: 6px solid #4cbd7a; }
        .carte h3 { margin: 0 0 5px 0; color: #1b4d3e; font-size: 14px; }
        .poids-affiche { font-size: 26px; font-weight: bold; color: #dd6b20; margin-top: 10px; }
        .dashboard-visuel { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 25px; margin-bottom: 35px; }
        @media (max-width: 768px) { .dashboard-visuel { grid-template-columns: 1fr; } }
        .zone-tableau, .zone-graphique { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 12px 15px; text-align: left; border-bottom: 1px solid #e2e8f0; }
        th { background-color: #1b4d3e; color: white; }
        .total-ligne { font-weight: bold; background-color: #edf2f7; }
        footer { text-align: center; margin-top: 50px; font-size: 14px; color: #a0aec0; }
    </style>
</head>
<body>

    <div class="wrapper">
        <header>
            <h1>Objectifs de Développement Durable — ODD 12</h1>
            <p>Collège du Vaucluse — Suivi du gaspillage de la cantine (700 demi-pensionnaires)</p>
        </header>

        <section class="zone-saisie">
            <h3>Saisie et modification des pesées</h3>
            <div class="form-grid">
                <div class="form-group">
                    <label for="input-serviettes">1. Serviettes papier (g)</label>
                    <input type="number" id="input-serviettes" value="900" min="0">
                </div>
                <div class="form-group">
                    <label for="input-emballages">2. Emballages (g)</label>
                    <input type="number" id="input-emballages" value="3500" min="0">
                </div>
                <div class="form-group">
                    <label for="input-alim">3. Déchets Alimentaires (g)</label>
                    <input type="number" id="input-alim" value="15200" min="0">
                </div>
                <div class="form-group">
                    <label for="input-fruits">4. Fruits entamés (g)</label>
                    <input type="number" id="input-fruits" value="2300" min="0">
                </div>
                <div class="form-group">
                    <label for="input-pain">5. Le Pain (g)</label>
                    <input type="number" id="input-pain" value="4100" min="0">
                </div>
                <div class="actions-btn">
                    <button class="btn btn-effacer" onclick="reinitialiser()">Remettre à Zéro</button>
                    <button class="btn btn-calculer" onclick="sauvegarderEtCalculer()">Sauvegarder & Mettre à jour</button>
                </div>
            </div>
            <div class="statut-sauvegarde" id="statut-sauvegarde">✓ Mémoire active : Vos données sont sécurisées.</div>
        </section>

        <main class="bloc-dechets">
            <div class="carte"><h3>1. Serviettes Papier</h3><div class="poids-affiche" id="card-serviettes">900 g</div></div>
            <div class="carte"><h3>2. Emballages</h3><div class="poids-affiche" id="card-emballages">3500 g</div></div>
            <div class="carte"><h3>3. Déchets Alimentaires</h3><div class="poids-affiche" id="card-alim">15200 g</div></div>
            <div class="carte"><h3>4. Fruits Entamés</h3><div class="poids-affiche" id="card-fruits">2300 g</div></div>
            <div class="carte"><h3>5. Le Pain</h3><div class="poids-affiche" id="card-pain">4100 g</div></div>
        </main>

        <div class="dashboard-visuel">
            <section class="zone-tableau">
                <table>
                    <thead>
                        <tr><th>Type de Poubelle</th><th>Poids Mesuré</th><th>Objectif de Réduction</th></tr>
                    </thead>
                    <tbody>
                        <tr><td><strong>1. Serviettes en papier</strong></td><td id="tab-serviettes">900 g</td><td>Prendre 1 seule serviette max</td></tr>
                        <tr><td><strong>2. Emballages</strong></td><td id="tab-emballages">3500 g</td><td>Favoriser le vrac en cuisine</td></tr>
                        <tr><td><strong>3. Déchets Alimentaires</strong></td><td id="tab-alim">15200 g</td><td>Passer sous la barre des 10 000 g</td></tr>
                        <tr><td><strong>4. Fruits entamés</strong></td><td id="tab-fruits">2300 g</td><td>Sensibiliser au gaspillage</td></tr>
                        <tr><td><strong>5. Le Pain</strong></td><td id="tab-pain">4100 g</td><td>Objectif : Zéro gâchis de pain</td></tr>
                        <tr class="total-ligne"><td>TOTAL DU REPAS</td><td id="tab-total">26000 g</td><td id="ratio-eleve">Soit 37g par élève</td></tr>
                    </tbody>
                </table>
            </section>
            <section class="zone-graphique"><canvas id="graphiqueDechets"></canvas></section>
        </div>
        <footer><p>© 2026 Projet Éco-Collège Vaucluse - Sensibilisation à l'ODD 12</p></footer>
    </div>

    <script>
        let monGraphique;

        window.onload = function() {
            if(localStorage.getItem('sauvegardeDonneesCantineG')) {
                const donnees = JSON.parse(localStorage.getItem('sauvegardeDonneesCantineG'));
                document.getElementById('input-serviettes').value = donnees.serviettes;
                document.getElementById('input-emballages').value = donnees.emballages;
                document.getElementById('input-alim').value = donnees.alim;
                document.getElementById('input-fruits').value = donnees.fruits;
                document.getElementById('input-pain').value = donnees.pain;
                document.getElementById('statut-sauvegarde').innerText = "💾 Données précédentes récupérées !";
            }
            initialiserGraphique();
            calculerEtMettreAJourInterface();
        };

        function initialiserGraphique() {
            const ctx = document.getElementById('graphiqueDechets').getContext('2d');
            monGraphique = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Serviettes', 'Emballages', 'Alimentaire', 'Fruits', 'Le Pain'],
                    datasets: [{
                        data: [0, 0, 0, 0, 0],
                        backgroundColor: ['#cbd5e0', '#ecc94b', '#dd6b20', '#3182ce', '#4cbd7a'],
                        borderWidth: 1
                    }]
                },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
        }

        function sauvegarderEtCalculer() {
            const structureDonnees = {
                serviettes: parseInt(document.getElementById('input-serviettes').value) || 0,
                emballages: parseInt(document.getElementById('input-emballages').value) || 0,
                alim: parseInt(document.getElementById('input-alim').value) || 0,
                fruits: parseInt(document.getElementById('input-fruits').value) || 0,
                pain: parseInt(document.getElementById('input-pain').value) || 0
            };
            localStorage.setItem('sauvegardeDonneesCantineG', JSON.stringify(structureDonnees));
            calculerEtMettreAJourInterface();
            
            const notification = document.getElementById('statut-sauvegarde');
            notification.innerText = "⚡ Sauvegardé en mémoire !";
            setTimeout(() => { notification.innerText = "✓ Vos modifications sont en sécurité."; }, 3000);
        }

        function calculerEtMettreAJourInterface() {
            const serv = parseInt(document.getElementById('input-serviettes').value) || 0;
            const emb = parseInt(document.getElementById('input-emballages').value) || 0;
            const alim = parseInt(document.getElementById('input-alim').value) || 0;
            const fr = parseInt(document.getElementById('input-fruits').value) || 0;
            const pn = parseInt(document.getElementById('input-pain').value) || 0;

            const total = serv + emb + alim + fr + pn;
            const gParEleve = Math.round(total / 700);

            document.getElementById('card-serviettes').innerText = serv + " g";
            document.getElementById('card-emballages').innerText = emb + " g";
            document.getElementById('card-alim').innerText = alim + " g";
            document.getElementById('card-fruits').innerText = fr + " g";
            document.getElementById('card-pain').innerText = pn + " g";

            document.getElementById('tab-serviettes').innerText = serv + " g";
            document.getElementById('tab-emballages').innerText = emb + " g";
            document.getElementById('tab-alim').innerText = alim + " g";
            document.getElementById('tab-fruits').innerText = fr + " g";
            document.getElementById('tab-pain').innerText = pn + " g";
            document.getElementById('tab-total').innerText = total + " g";
            document.getElementById('ratio-eleve').innerText = "Soit " + gParEleve + "g par élève (Sur 700 demi-pensionnaires)";

            if (monGraphique) {
                monGraphique.data.datasets[0].data = [serv, emb, alim, fr, pn];
                monGraphique.update();
            }
        }

        function reinitialiser() {
            if(confirm("Remettre à zéro ?")) {
                localStorage.removeItem('sauvegardeDonneesCantineG');
                document.getElementById('input-serviettes').value = 0;
                document.getElementById('input-emballages').value = 0;
                document.getElementById('input-alim').value = 0;
                document.getElementById('input-fruits').value = 0;
                document.getElementById('input-pain').value = 0;
                calculerEtMettreAJourInterface();
            }
        }
    </script>
</body>
</html>
