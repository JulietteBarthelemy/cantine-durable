
        
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Suivi Multi-Graphiques Cantine</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f3f4f6; color: #1f2937; margin: 0; padding: 20px; }
        .container { max-width: 1200px; margin: 0 auto; }
        header { background-color: #1b4d3e; color: white; padding: 20px; text-align: center; border-radius: 12px; margin-bottom: 25px; }
        h2, h3 { color: #1b4d3e; margin-top: 0; }
        
        /* Grille principale des blocs */
        .grid-bloc { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 20px; margin-bottom: 25px; }
        .bloc { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border-top: 5px solid #dd6b20; }
        .bloc.annee { border-top-color: #3182ce; grid-column: 1 / -1; }
        
        /* Formulaires de saisie */
        .form-mini { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 15px; }
        .form-mini.annee-grid { grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); }
        .group { display: flex; flex-direction: column; }
        .group label { font-size: 11px; font-weight: bold; color: #4b5563; margin-bottom: 2px; }
        .group input { padding: 6px; border: 1px solid #d1d5db; border-radius: 6px; font-weight: bold; font-size: 13px; }
        
        .btn-save { width: 100%; padding: 10px; background-color: #1b4d3e; color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; }
        .btn-save:hover { background-color: #2c6b56; }
        .btn-reset { background-color: #e53e3e; color: white; padding: 10px 20px; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; float: right; margin-top: -50px; }
        
        canvas { max-height: 200px; margin-top: 15px; }
        .canvas-grand { max-height: 300px; }
    </style>
</head>
<body>

    <div class="container">
        <header>
            <h1>Suivi Réel du Gaspillage — Collège du Vaucluse</h1>
            <p>Saisissez vos données directement dans chaque tableau. Tout est mémorisé.</p>
            <button class="btn-reset" onclick="reinitialiserTout()">Tout effacer</button>
        </header>

        <div class="grid-bloc">
            
            <!-- BLOC 1 : DERNIERE SAISIE -->
            <div class="bloc">
                <h3>📊 1. Dernière Saisie (g)</h3>
                <div class="form-mini">
                    <div class="group"><label>Serviettes</label><input type="number" id="j-1" value="900"></div>
                    <div class="group"><label>Emballages</label><input type="number" id="j-2" value="3500"></div>
                    <div class="group"><label>Alimentaire</label><input type="number" id="j-3" value="15200"></div>
                    <div class="group"><label>Fruits</label><input type="number" id="j-4" value="2300"></div>
                    <div class="group"><label>Pain</label><input type="number" id="j-5" value="4100"></div>
                </div>
                <button class="btn-save" onclick="sauvegarderEtMettreAJour()">Mettre à jour le jour</button>
                <canvas id="chartJour"></canvas>
            </div>

            <!-- BLOC 2 : SEMAINE 1 -->
            <div class="bloc">
                <h3>📅 2. Semaine 1 du Mois (g)</h3>
                <div class="form-mini">
                    <div class="group"><label>Serviettes</label><input type="number" id="s1-1" value="4000"></div>
                    <div class="group"><label>Emballages</label><input type="number" id="s1-2" value="15000"></div>
                    <div class="group"><label>Alimentaire</label><input type="number" id="s1-3" value="70000"></div>
                    <div class="group"><label>Fruits</label><input type="number" id="s1-4" value="10000"></div>
                    <div class="group"><label>Pain</label><input type="number" id="s1-5" value="18000"></div>
                </div>
                <button class="btn-save" onclick="sauvegarderEtMettreAJour()">Mettre à jour Semaine 1</button>
                <canvas id="chartS1"></canvas>
            </div>

            <!-- BLOC 3 : SEMAINE 2 -->
            <div class="bloc">
                <h3>📅 3. Semaine 2 du Mois (g)</h3>
                <div class="form-mini">
                    <div class="group"><label>Serviettes</label><input type="number" id="s2-1" value="4200"></div>
                    <div class="group"><label>Emballages</label><input type="number" id="s2-2" value="14200"></div>
                    <div class="group"><label>Alimentaire</label><input type="number" id="s2-3" value="68000"></div>
                    <div class="group"><label>Fruits</label><input type="number" id="s2-4" value="9500"></div>
                    <div class="group"><label>Pain</label><input type="number" id="s2-5" value="17500"></div>
                </div>
                <button class="btn-save" onclick="sauvegarderEtMettreAJour()">Mettre à jour Semaine 2</button>
                <canvas id="chartS2"></canvas>
            </div>

            <!-- BLOC 4 : SEMAINE 3 -->
            <div class="bloc">
                <h3>📅 4. Semaine 3 du Mois (g)</h3>
                <div class="form-mini">
                    <div class="group"><label>Serviettes</label><input type="number" id="s3-1" value="3800"></div>
                    <div class="group"><label>Emballages</label><input type="number" id="s3-2" value="16000"></div>
                    <div class="group"><label>Alimentaire</label><input type="number" id="s3-3" value="72000"></div>
                    <div class="group"><label>Fruits</label><input type="number" id="s3-4" value="11000"></div>
                    <div class="group"><label>Pain</label><input type="number" id="s3-5" value="19000"></div>
                </div>
                <button class="btn-save" onclick="sauvegarderEtMettreAJour()">Mettre à jour Semaine 3</button>
                <canvas id="chartS3"></canvas>
            </div>

            <!-- BLOC 5 : SEMAINE 4 -->
            <div class="bloc">
                <h3>📅 5. Semaine 4 du Mois (g)</h3>
                <div class="form-mini">
                    <div class="group"><label>Serviettes</label><input type="number" id="s4-1" value="3900"></div>
                    <div class="group"><label>Emballages</label><input type="number" id="s4-2" value="13500"></div>
                    <div class="group"><label>Alimentaire</label><input type="number" id="s4-3" value="65000"></div>
                    <div class="group"><label>Fruits</label><input type="number" id="s4-4" value="8900"></div>
                    <div class="group"><label>Pain</label><input type="number" id="s4-5" value="16000"></div>
                </div>
                <button class="btn-save" onclick="sauvegarderEtMettreAJour()">Mettre à jour Semaine 4</button>
                <canvas id="chartS4"></canvas>
            </div>

            <!-- BLOC 6 : TOUTE L'ANNEE (SUR TOUT L'ECRAN) -->
            <div class="bloc annee">
                <h3>📈 6. Saisie Globale de l'Année par Mois (g)</h3>
                <div class="form-mini annee-grid">
                    <div class="group"><label>Septembre</label><input type="number" id="m-9" value="110000"></div>
                    <div class="group"><label>Octobre</label><input type="number" id="m-10" value="125000"></div>
                    <div class="group"><label>Novembre</label><input type="number" id="m-11" value="140000"></div>
                    <div class="group"><label>Décembre</label><input type="number" id="m-12" value="95000"></div>
                    <div class="group"><label>Janvier</label><input type="number" id="m-1" value="120000"></div>
                    <div class="group"><label>Février</label><input type="number" id="m-2" value="115000"></div>
                    <div class="group"><label>Mars</label><input type="number" id="m-3" value="105000"></div>
                    <div class="group"><label>Avril</label><input type="number" id="m-4" value="98000"></div>
                    <div class="group"><label>Mai</label><input type="number" id="m-5" value="112000"></div>
                    <div class="group"><label>Juin</label><input type="number" id="m-6" value="85000"></div>
                </div>
                <button class="btn-save" style="margin-top: 10px;" onclick="sauvegarderEtMettreAJour()">Mettre à jour le graphique Annuel</button>
                <canvas id="chartAnnee" class="canvas-grand"></canvas>
            </div>

        </div>
    </div>

    <script>
        // Références des graphiques
        let cJour, cS1, cS2, cS3, cS4, cAnnee;
        const labelsPoubelles = ['Serviettes', 'Emballages', 'Alimentaire', 'Fruits', 'Pain'];
        const couleurs = ['#cbd5e0', '#ecc94b', '#dd6b20', '#3182ce', '#4cbd7a'];

        window.onload = function() {
            initialiserGraphiques();
            
            // Si une sauvegarde existe, on remplace les valeurs écrites à l'écran
            if(localStorage.getItem('sauvegardeDirecteCantine')) {
                const memoire = JSON.parse(localStorage.getItem('sauvegardeDirecteCantine'));
                for (const id in memoire) {
                    if(document.getElementById(id)) {
                        document.getElementById(id).value = memoire[id];
                    }
                }
            }
            rafraichirGraphiques();
        };

        function initialiserGraphiques() {
            cJour = new Chart(document.getElementById('chartJour'), { type: 'doughnut', data: { labels: labelsPoubelles, datasets: [{ data: [0,0,0,0,0], backgroundColor: couleurs }] }, options: { plugins: { legend: { display: false } } } });
            cS1 = new Chart(document.getElementById('chartS1'), { type: 'bar', data: { labels: labelsPoubelles, datasets: [{ label: 'Semaine 1', data: [0,0,0,0,0], backgroundColor: '#3182ce' }] } });
            cS2 = new Chart(document.getElementById('chartS2'), { type: 'bar', data: { labels: labelsPoubelles, datasets: [{ label: 'Semaine 2', data: [0,0,0,0,0], backgroundColor: '#3182ce' }] } });
            cS3 = new Chart(document.getElementById('chartS3'), { type: 'bar', data: { labels: labelsPoubelles, datasets: [{ label: 'Semaine 3', data: [0,0,0,0,0], backgroundColor: '#3182ce' }] } });
            cS4 = new Chart(document.getElementById('chartS4'), { type: 'bar', data: { labels: labelsPoubelles, datasets: [{ label: 'Semaine 4', data: [0,0,0,0,0], backgroundColor: '#3182ce' }] } });
            
            cAnnee = new Chart(document.getElementById('chartAnnee'), { 
                type: 'line', 
                data: { 
                    labels: ['Sept', 'Oct', 'Nov', 'Déc', 'Janv', 'Févr', 'Mars', 'Avril', 'Mai', 'Juin'], 
                    datasets: [{ label: 'Total Déchets du mois (g)', data: new Array(10).fill(0), borderColor: '#1b4d3e', tension: 0.1, fill: true, backgroundColor: 'rgba(27, 77, 62, 0.1)' }] 
                },
                options: { responsive: true, maintainAspectRatio: false }
            });
        }

        function sauvegarderEtMettreAJour() {
            // On attrape tous les inputs de la page pour créer le dictionnaire de sauvegarde
            const listeInputs = document.querySelectorAll('input[type="number"]');
            let etatActuel = {};
            
            listeInputs.forEach(input => {
                etatActuel[input.id] = parseInt(input.value) || 0;
            });

            // Sauvegarde brute dans le navigateur
            localStorage.setItem('sauvegardeDirecteCantine', JSON.stringify(etatActuel));
            
            // Rafraîchir les visuels
            rafraichirGraphiques();
        }

        function rafraichirGraphiques() {
            const getVal = (id) => parseInt(document.getElementById(id).value) || 0;

            // Update Jour (Camembert)
            cJour.data.datasets[0].data = [getVal('j-1'), getVal('j-2'), getVal('j-3'), getVal('j-4'), getVal('j-5')];
            cJour.update();

            // Update Semaine 1
            cS1.data.datasets[0].data = [getVal('s1-1'), getVal('s1-2'), getVal('s1-3'), getVal('s1-4'), getVal('s1-5')];
            cS1.update();

            // Update Semaine 2
            cS2.data.datasets[0].data = [getVal('s2-1'), getVal('s2-2'), getVal('s2-3'), getVal('s2-4'), getVal('s2-5')];
            cS2.update();

            // Update Semaine 3
            cS3.data.datasets[0].data = [getVal('s3-1'), getVal('s3-2'), getVal('s3-3'), getVal('s3-4'), getVal('s3-5')];
            cS3.update();

            // Update Semaine 4
            cS4.data.datasets[0].data = [getVal('s4-1'), getVal('s4-2'), getVal('s4-3'), getVal('s4-4'), getVal('s4-5')];
            cS4.update();

            // Update Année (Dans l'ordre scolaire : Sept à Juin)
            cAnnee.data.datasets[0].data = [
                getVal('m-9'), getVal('m-10'), getVal('m-11'), getVal('m-12'),
                getVal('m-1'), getVal('m-2'), getVal('m-3'), getVal('m-4'), getVal('m-5'), getVal('m-6')
            ];
            cAnnee.update();
        }

        function reinitialiserTout() {
            if(confirm("Voulez-vous effacer toutes les données saisies à l'écran ?")) {
                localStorage.removeItem('sauvegardeDirecteCantine');
                const listeInputs = document.querySelectorAll('input[type="number"]');
                listeInputs.forEach(input => input.value = 0);
                rafraichirGraphiques();
            }
        }
    </script>
</body>
</html>
