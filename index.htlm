<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mon Graphique Rond Cantine</title>
    <!-- Chargement sécurisé de la bibliothèque des graphiques -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js" defer></script>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f3f4f6; padding: 20px; color: #1f2937; }
        .container { max-width: 600px; margin: 0 auto; background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h2 { color: #1b4d3e; text-align: center; margin-top: 0; }
        .form-group { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        label { font-weight: bold; font-size: 14px; }
        input { padding: 8px; width: 100px; border: 1px solid #d1d5db; border-radius: 6px; font-weight: bold; text-align: right; }
        .btn { width: 100%; padding: 12px; background-color: #1b4d3e; color: white; border: none; border-radius: 6px; font-weight: bold; font-size: 16px; cursor: pointer; margin-top: 15px; }
        .btn:hover { background-color: #2c6b56; }
        .zone-graphique { margin-top: 25px; display: flex; justify-content: center; }
        canvas { max-width: 1000px; max-height: 320px; }
    </style>
</head>
<body>

    <div class="container">
        <h2>📊 Suivi des 5 Poubelles</h2>
        
        <!-- ZONE DE SAISIE -->
        <div class="form-group">
            <label>1. Serviettes en papier (g)</label>
            <input type="number" id="p1" value="900">
        </div>
        <div class="form-group">
            <label>2. Emballages (g)</label>
            <input type="number" id="p2" value="3500">
        </div>
        <div class="form-group">
            <label>3. Déchets alimentaires (g)</label>
            <input type="number" id="p3" value="15200">
        </div>
        <div class="form-group">
            <label>4. Fruits entamés (g)</label>
            <input type="number" id="p4" value="2300">
        </div>
        <div class="form-group">
            <label>5. Le pain (g)</label>
            <input type="number" id="p5" value="4100">
        </div>

        <button class="btn" onclick="sauvegarderEtAfficher()">Enregistrer & Mettre à jour le graphique</button>

        <!-- ZONE DU GRAPHIQUE ROND -->
        <div class="zone-graphique">
            <canvas id="monGraphiqueRond"></canvas>
        </div>
    </div>

    <script>
        let monCamembert;

        // ÉTAPE 1 : On attend que toute la page ET le script Chart.js soient chargés
        document.addEventListener("DOMContentLoaded", function() {
            // Récupération de la mémoire si elle existe
            if(localStorage.getItem('memoirePoubellesG')) {
                const donneesSauvegardees = JSON.parse(localStorage.getItem('memoirePoubellesG'));
                document.getElementById('p1').value = donneesSauvegardees.v1;
                document.getElementById('p2').value = donneesSauvegardees.v2;
                document.getElementById('p3').value = donneesSauvegardees.v3;
                document.getElementById('p4').value = donneesSauvegardees.v4;
                document.getElementById('p5').value = donneesSauvegardees.v5;
            }
            
            // Lancement du graphique rond
            creerLeGraphiqueRond();
        });

        // ÉTAPE 2 : Création initiale du graphique rond
        function creerLeGraphiqueRond() {
            const ctx = document.getElementById('monGraphiqueRond').getContext('2d');
            
            const v1 = parseInt(document.getElementById('p1').value) || 0;
            const v2 = parseInt(document.getElementById('p2').value) || 0;
            const v3 = parseInt(document.getElementById('p3').value) || 0;
            const v4 = parseInt(document.getElementById('p4').value) || 0;
            const v5 = parseInt(document.getElementById('p5').value) || 0;

            monCamembert = new Chart(ctx, {
                type: 'pie', // Type 'pie' = Graphique Rond / Camembert
                data: {
                    labels: ['Serviettes', 'Emballages', 'Déchets Alim.', 'Fruits entamés', 'Le pain'],
                    datasets: [{
                        data: [v1, v2, v3, v4, v5],
                        backgroundColor: ['#9ca3af', '#f59e0b', '#ef4444', '#3b82f6', '#10b981'],
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });
        }

        // ÉTAPE 3 : Action quand on clique sur le bouton vert
        function sauvegarderEtAfficher() {
            const valeurs = {
                v1: parseInt(document.getElementById('p1').value) || 0,
                v2: parseInt(document.getElementById('p2').value) || 0,
                v3: parseInt(document.getElementById('p3').value) || 0,
                v4: parseInt(document.getElementById('p4').value) || 0,
                v5: parseInt(document.getElementById('p5').value) || 0
            };

            // Sauvegarde permanente dans le navigateur
            localStorage.setItem('memoirePoubellesG', JSON.stringify(valeurs));

            // Mise à jour instantanée du graphique rond
            if (monCamembert) {
                monCamembert.data.datasets[0].data = [valeurs.v1, valeurs.v2, valeurs.v3, valeurs.v4, valeurs.v5];
                monCamembert.update();
            }
        }
    </script>
</body>
</html>
