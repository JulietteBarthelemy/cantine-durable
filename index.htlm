<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Suivi Annuel - Canti-Gâchis v3</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f7faf7; color: #2d3748; margin: 0; padding: 20px; }
        .wrapper { max-width: 1100px; margin: 0 auto; }
        header { background-color: #1b4d3e; color: white; padding: 20px; text-align: center; border-radius: 12px; margin-bottom: 25px; }
        header h1 { margin: 0 0 5px 0; font-size: 24px; }
        
        /* SYSTÈME D'ONGLETS */
        .onglets { display: flex; gap: 10px; margin-bottom: 20px; }
        .onglet-btn { padding: 12px 20px; background-color: #e2e8f0; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; font-size: 14px; transition: 0.3s; }
        .onglet-btn.active { background-color: #1b4d3e; color: white; }
        .contenu-onglet { display: none; }
        .contenu-onglet.active { display: block; }

        .zone-blanche { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); margin-bottom: 25px; }
        .grid-2 { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 25px; }
        @media (max-width: 768px) { .grid-2 { grid-template-columns: 1fr; } }

        .form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin: 15px 0; }
        .form-group { display: flex; flex-direction: column; }
        .form-group label { font-size: 12px; font-weight: bold; margin-bottom: 5px; color: #4a5568; }
        .form-group input, .form-group select { padding: 10px; border: 2px solid #e2e8f0; border-radius: 8px; font-size: 15px; font-weight: bold; }
        
        .btn { padding: 12px 20px; border-radius: 8px; cursor: pointer; font-weight: bold; border: none; }
        .btn-principal { background-color: #1b4d3e; color: white; }
        .btn-danger { background-color: #e53e3e; color: white; }

        table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #e2e8f0; font-size: 14px; }
        th { background-color: #1b4d3e; color: white; }
        .total-ligne { font-weight: bold; background-color: #edf2f7; }
        .statut { font-size: 13px; color: #2b6cb0; font-style: italic; margin-top: 10px; font-weight: bold; }
    </style>
</head>
<body>

    <div class="wrapper">
        <header>
            <h1>Canti-Gâchis v3 — Tableaux de Bord Multi-Graphiques</h1>
            <p>Collège du Vaucluse — Suivi du gaspillage (700 demi-pensionnaires)</p>
        </header>

        <div class="onglets">
            <button class="onglet-btn active" onclick="changerOnglet(event, 'onglet-saisie')">📊 Saisie du Jour & Camembert</button>
            <button class="onglet-btn" onclick="changerOnglet(event, 'onglet-mois')">📅 Comparatif Mensuel (S1 à S4)</button>
            <button class="onglet-btn" onclick="changerOnglet(event, 'onglet-annee')">📈 Évolution sur l'Année</button>
        </div>

        <div id="onglet-saisie" class="contenu-onglet active">
            <div class="zone-blanche">
                <h3>Saisie de la dernière pesée</h3>
                <div class="form-grid">
                    <div class="form-group">
                        <label>1. Serviettes papier (g)</label>
                        <input type="number" id="input-serviettes" value="900">
                    </div>
                    <div class="form-group">
                        <label>2. Emballages (g)</label>
                        <input type="number" id="input-emballages" value="3500">
                    </div>
                    <div class="form-group">
                        <label>3. Déchets Alimentaires (g)</label>
                        <input type="number" id="input-alim" value="15200">
                    </div>
                    <div class="form-group">
                        <label>4. Fruits entamés (g)</label>
                        <input type="number" id="input-fruits" value="2300">
                    </div>
                    <div class="form-group">
                        <label>5. Le Pain (g)</label>
                        <input type="number" id="input-pain" value="4100">
                    </div>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <button class="btn btn-principal" onclick="sauvegarderJour()">Sauvegarder cette pesée</button>
                    <div id="statut-saisie" class="statut">✓ Prêt à enregistrer</div>
                </div>
            </div>

            <div class="grid-2">
                <div class="zone-blanche">
                    <h3>Récapitulatif de la dernière saisie</h3>
                    <table>
                        <thead>
                            <tr><th>Poubelle</th><th>Poids</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>1. Serviettes en papier</td><td id="tab-serviettes">0 g</td></tr>
                            <tr><td>2. Emballages</td><td id="tab-emballages">0 g</td></tr>
                            <tr><td>3. Déchets Alimentaires</td><td id="tab-alim">0 g</td></tr>
                            <tr><td>4. Fruits entamés</td><td id="tab-fruits">0 g</td></tr>
                            <tr><td>5. Le Pain</td><td id="tab-pain">0 g</td></tr>
                            <tr class="total-ligne"><td>TOTAL</td><td id="tab-total">0 g</td></tr>
                            <tr class="total-ligne" style="color: #dd6b20;"><td>Moyenne / Élève</td><td id="tab-ratio">0 g / élève</td></tr>
                        </tbody>
                    </table>
                </div>
                <div class="zone-blanche">
                    <h3>Répartition (Dernière saisie)</h3>
                    <canvas id="graphiqueCamembert" style="max-height: 280px;"></canvas>
                </div>
            </div>
        </div>

        <div id="onglet-mois" class="contenu-onglet">
            <div class="zone-blanche">
                <h3>Attribuer le total du jour à une semaine du mois</h3>
                <p style="font-size: 14px; color:#4a5568;">Sélectionnez la semaine en cours pour y injecter le total calculé dans l'onglet 1 :</p>
                <div style="display: flex; gap: 15px; align-items: center;">
                    <select id="select-semaine" style="padding: 10px; border-radius: 8px; font-weight: bold;">
                        <option value="S1">Semaine 1</option>
                        <option value="S2">Semaine 2</option>
                        <option value="S3">Semaine 3</option>
                        <option value="S4">Semaine 4</option>
                    </select>
                    <button class="btn btn-principal" onclick="envoyerVersSemaine()">Enregistrer pour cette semaine</button>
                </div>
            </div>
            <div class="grid-2">
                <div class="zone-blanche">
                    <h3>Historique du Mois (Total en grammes)</h3>
                    <canvas id="graphiqueMois"></canvas>
                </div>
                <div class="zone-blanche">
                    <h3>Détails du mois</h3>
                    <p style="font-size: 14px;">Chaque barre représente le poids total cumulé de vos 5 poubelles sur la semaine donnée.</p>
                </div>
            </div>
        </div>

        <div id="onglet-annee" class="contenu-onglet">
            <div class="zone-blanche">
                <h3>Envoyer le score global du mois vers l'historique annuel</h3>
                <div style="display: flex; gap: 15px; align-items: center;">
                    <select id="select-mois" style="padding: 10px; border-radius: 8px; font-weight: bold;">
                        <option value="0">Janvier</option><option value="1">Février</option><option value="2">Mars</option>
                        <option value="3">Avril</option><option value="4">Mai</option><option value="5">Juin</option>
                        <option value="6">Juillet</option><option value="7">Août</option><option value="8">Septembre</option>
                        <option value="9">Octobre</option><option value="10">Novembre</option><option value="11">Décembre</option>
                    </select>
                    <button class="btn btn-principal" onclick="envoyerVersAnnee()">Enregistrer pour ce mois</button>
                    <button class="btn btn-danger" onclick="RAZ_Totale()">Tout Effacer la mémoire</button>
                </div>
            </div>
            <div class="zone-blanche">
                <h3>Évolution sur l'année scolaire (en grammes)</h3>
                <canvas id="graphiqueAnnee" style="max-height: 300px;"></canvas>
            </div>
        </div>

        <footer>
            <p>© 2026 Projet Éco-Collège Vaucluse - ODD 12</p>
        </footer>
    </div>

    <script>
        // --- VARIABLES GLOBALES DES GRAPHIQUES ---
        let chartCamembert, chartMois, chartAnnee;

        // --- STRUCTURE DES DONNÉES PAR DÉFAUT ---
        let donneesProjet = {
            dernierJour: { serviettes: 900, emballages: 3500, alim: 15200, fruits: 2300, pain: 4100 },
            semaines: { S1: 22000, S2: 26000, S3: 19000, S4: 24000 },
            annee: [120000, 115000, 95000, 105000, 110000, 80000, 0, 0, 130000, 125000, 140000, 118000]
        };

        window.onload = function() {
            // Charger la mémoire si elle existe
            if(localStorage.getItem('cantiGachisMemoire')) {
                donneesProjet = JSON.parse(localStorage.getItem('cantiGachisMemoire'));
            }

            // Mettre les valeurs de la mémoire dans les cases de saisie
            document.getElementById('input-serviettes').value = donneesProjet.dernierJour.serviettes;
            document.getElementById('input-emballages').value = donneesProjet.dernierJour.emballages;
            document.getElementById('input-alim').value = donneesProjet.dernierJour.alim;
            document.getElementById('input-fruits').value = donneesProjet.dernierJour.fruits;
            document.getElementById('input-pain').value = donneesProjet.dernierJour.pain;

            // Créer TOUS les graphiques proprement dès le départ
            creerGraphiques();
            rafraichirInterface();
        };

        function creerGraphiques() {
            // 1. Le Camembert (Dernière Saisie)
            const ctx1 = document.getElementById('graphiqueCamembert').getContext('2d');
            chartCamembert = new Chart(ctx1, {
                type: 'doughnut',
                data: {
                    labels: ['Serviettes', 'Emballages', 'Alimentaire', 'Fruits', 'Pain'],
                    datasets: [{
                        data: [0, 0, 0, 0, 0],
                        backgroundColor: ['#cbd5e0', '#ecc94b', '#dd6b20', '#3182ce', '#4cbd7a']
                    }]
                },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });

            // 2. Le graphique du Mois (Barres Semaines)
            const ctx2 = document.getElementById('graphiqueMois').getContext('2d');
            chartMois = new Chart(ctx2, {
                type: 'bar',
                data: {
                    labels: ['Semaine 1', 'Semaine 2', 'Semaine 3', 'Semaine 4'],
                    datasets: [{
                        label: 'Déchets totaux (g)',
                        data: [0, 0, 0, 0],
                        backgroundColor: '#3182ce'
                    }]
                },
                options: { responsive: true }
            });

            // 3. Le graphique de l'Année (Ligne Évolution)
            const ctx3 = document.getElementById('graphiqueAnnee').getContext('2d');
            chartAnnee = new Chart(ctx3, {
                type: 'line',
                data: {
                    labels: ['Janv', 'Févr', 'Mars', 'Avril', 'Mai', 'Juin', 'Juil', 'Août', 'Sept', 'Oct', 'Nov', 'Déc'],
                    datasets: [{
                        label: 'Gaspillage mensuel global (g)',
                        data: new Array(12).fill(0),
                        borderColor: '#1b4d3e',
                        backgroundColor: 'rgba(27, 77, 62, 0.1)',
                        fill: true,
                        tension: 0.2
                    }]
                },
                options: { responsive: true }
            });
        }

        function rafraichirInterface() {
            // Lecture des inputs de l'onglet 1
            const s = parseInt(document.getElementById('input-serviettes').value) || 0;
            const e = parseInt(document.getElementById('input-emballages').value) || 0;
            const a = parseInt(document.getElementById('input-alim').value) || 0;
            const f = parseInt(document.getElementById('input-fruits').value) || 0;
            const p = parseInt(document.getElementById('input-pain').value) || 0;

            const totalJour = s + e + a + f + p;
            const ratio = Math.round(totalJour / 700);

            // Remplir le tableau récapitulatif
            document.getElementById('tab-serviettes').innerText = s + " g";
            document.getElementById('tab-emballages').innerText = e + " g";
            document.getElementById('tab-alim').innerText = a + " g";
            document.getElementById('tab-fruits').innerText = f + " g";
            document.getElementById('tab-pain').innerText = p + " g";
            document.getElementById('tab-total').innerText = totalJour + " g";
            document.getElementById('tab-ratio').innerText = ratio + " g / élève";

            // Mettre à jour les données du camembert
            chartCamembert.data.datasets[0].data = [s, e, a, f, p];
            chartCamembert.update();

            // Mettre à jour le graphique du mois
            chartMois.data.datasets[0].data = [
                donneesProjet.semaines.S1,
                donneesProjet.semaines.S2,
                donneesProjet.semaines.S3,
                donneesProjet.semaines.S4
            ];
            chartMois.update();

            // Mettre à jour le graphique de l'année
            chartAnnee.data.datasets[0].data = donneesProjet.annee;
            chartAnnee.update();
        }

        function sauvegarderJour() {
            donneesProjet
